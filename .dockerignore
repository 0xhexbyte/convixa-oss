# Dependencies
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Next.js
.next
out

# Production
build
dist

# Misc
.DS_Store
*.pem

# Debug
*.log

# Local env files (never bake secrets into image; pass via docker-compose environment:)
.env

# Vercel
.vercel

# TypeScript
*.tsbuildinfo

# IDE
.vscode
.idea
.cursor

# Git
.git
.gitignore

# Docker
Dockerfile
docker-compose*.yml
.dockerignore

# Database (don't copy local database)
*.db
*.db-journal

# Test
coverage
.nyc_output

# Drizzle schema snapshots — not needed at runtime, but _journal.json must be included
# because drizzle-kit migrate requires it to track applied migrations
drizzle/meta/*_snapshot.json

# Docs and planning files — never needed in the image
docs
plans
*.md
LICENSE

# Test and CI
.github
.husky
*.test.ts
*.spec.ts
__tests__
__mocks__
