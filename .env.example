# Local dev / Docker dev mode template
# Copy to .env: cp .env.example .env
#
# PRODUCTION NOTE: When deploying via deploy.sh (Docker blue-green),
#   - Use DATABASE_URL with the postgres container name (not localhost)
#   - Set APP_URL and NEXTAUTH_URL to your public domain (https://yourdomain.com)
#   - All vars marked REQUIRED below must be present or the feature will fail

# ── Database ──────────────────────────────────────────────────────────────────
# Local: postgresql://user:password@localhost:5432/convixa
# Docker full-stack / deploy.sh: postgresql://convixa:convixa_password@postgres:5432/convixa
# Hosted (Neon / Supabase / Railway / Render): use the provider's connection string
DATABASE_URL=postgresql://user:password@localhost:5432/convixa

# ── Auth ──────────────────────────────────────────────────────────────────────
# REQUIRED. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-at-least-32-chars
# REQUIRED. Set to your public domain in production (e.g. https://yourdomain.com)
NEXTAUTH_URL=http://localhost:3001
# Used in invite links and auth redirects.
# Must match NEXTAUTH_URL in most setups; set explicitly so logout and invite links
# use the correct URL. In production: https://yourdomain.com
APP_URL=http://localhost:3001

# Optional: Sign in with Google (OAuth). Create OAuth 2.0 credentials at https://console.cloud.google.com/apis/credentials
# Set authorized redirect URI to: {NEXTAUTH_URL}/api/auth/callback/google
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=xxx

# Optional: WalletConnect project ID (get one at https://cloud.walletconnect.com)
# NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Optional: Override the base URL used in auth redirects and invite links.
# Defaults to APP_URL or NEXTAUTH_URL when not set. Useful for tunnel testing (e.g. Cloudflare Tunnel).
# NEXT_PUBLIC_APP_BASE_URL=

# ── Email ──────────────────────────────────────────────────────────────────────
# Optional for 2FA OTP emails + subscription lifecycle emails (welcome, cancel, etc).
# Without this, OTP is logged to the console only and no subscription emails are sent.
# Get an API key at https://resend.com (free tier: 100 emails/day).
# RESEND_API_KEY=re_xxxxxxxxxxxx
# Sender shown in emails (Resend lets you use onboarding@resend.dev for testing):
# EMAIL_FROM=Convixa <onboarding@resend.dev>

# Dev only: inject a fake unsigned pending tx into Signer Queue + Security → Pending reviews.
# Requires NODE_ENV !== production. Restart the dev server after enabling.
# SIGNER_QUEUE_DEV_SIMULATE=true

# ── Safe Transaction Service ───────────────────────────────────────────────────
# Optional: API key from https://developer.safe.global/ — avoids unauthenticated rate limits (2 RPS / 5k units/mo).
# SAFE_API_KEY=your-jwt-api-key

# ── SEAL compliance (optional) ─────────────────────────────────────────────────
# Rough ETH/USD for asset-band estimates in compliance scorecards (default 3000).
# ETH_USD_ESTIMATE=3000

# Block explorer API key for signer EOA activity watch (Etherscan-family explorers).
# ETHERSCAN_API_KEY=your-etherscan-api-key

# Affiliation proof TTL in days before verification is considered expired (default 365).
# AFFILIATION_PROOF_TTL_DAYS=365

# Phase 3 operational workflows — incident notifications and SLA defaults.
# SECURITY_CONTACT_EMAIL receives medium+ severity incident reports via Resend.
# SECURITY_CONTACT_EMAIL=security@yourcompany.com
# OOB_VERIFICATION_SLA_HOURS=48
# PENDING_TX_REVIEW_SLA_HOURS=24

# Phase 4 readiness — drills, onboarding SLA, weekly snapshots.
# READINESS_DRILL_GRACE_DAYS=7
# READINESS_ONBOARDING_SLA_DAYS=30
# READINESS_SNAPSHOT_ENABLED=true

# Phase 5 governance — timelocks, webhooks, simulation, certification.
# SAFE_WEBHOOK_BASE_URL=https://your-host.com/api/webhooks/safe-tx-service
# SAFE_WEBHOOKS_ENABLED=true
# TX_SIMULATION_ENABLED=true
# TX_SIMULATION_CACHE_TTL_HOURS=24
# TENDERLY_ACCESS_KEY=
# TENDERLY_ACCOUNT_SLUG=
# TENDERLY_PROJECT_SLUG=

# ── Alerting / Cron ────────────────────────────────────────────────────────────
# Poll interval in ms (default 15000). Cron should hit GET /api/cron/alerts-poll every POLL_INTERVAL_MS.
# ALERT_POLL_INTERVAL_MS=15000
# Optional: secure the cron endpoint. Send header: Authorization: Bearer <CRON_SECRET>
# CRON_SECRET=your-cron-secret
# Optional: default Slack webhook for alerts (per-subscription webhooks can override this).
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx
