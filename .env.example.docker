# Docker Full Stack Mode - Environment Template
# Used by: npm run docker:full (local full-stack) and deploy.sh (production blue-green)
# Copy to .env: cp .env.example.docker .env

# ── Database ──────────────────────────────────────────────────────────────────
# DATABASE_URL is pre-configured for the Docker internal network (app → postgres container).
# Do NOT use localhost:5432 — the app runs inside Docker and must reach postgres by service name.
DATABASE_URL=postgresql://convixa:convixa_password@postgres:5432/convixa
# If `docker:full` or deploy.sh fails with "Bind for 0.0.0.0:5432 failed: port is already allocated":
# POSTGRES_PUBLISH_PORT=5433

# ── Auth ──────────────────────────────────────────────────────────────────────
# REQUIRED. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=please-change-this-to-a-secure-random-string-at-least-32-characters
# REQUIRED. Set to your public domain in production (e.g. https://yourdomain.com)
NEXTAUTH_URL=http://localhost:3000
# REQUIRED. Used in auth redirects and invite links.
# In production, set to your public domain: https://yourdomain.com
APP_URL=http://localhost:3000

# Optional: Sign in with Google.
# In Google Cloud Console, add authorized redirect URI:
#   https://yourdomain.com/api/auth/callback/google
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=xxx

# Optional: WalletConnect project ID
# NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ── Email ──────────────────────────────────────────────────────────────────────
# Optional for 2FA OTP emails.
# Without this, OTP is logged to console only.
# RESEND_API_KEY=re_xxxxxxxxxxxx
# EMAIL_FROM=Convixa <onboarding@resend.dev>

# ── SEAL compliance (optional) ─────────────────────────────────────────────────
# ETHERSCAN_API_KEY=your-etherscan-api-key
# AFFILIATION_PROOF_TTL_DAYS=365
# SECURITY_CONTACT_EMAIL=security@yourcompany.com
# OOB_VERIFICATION_SLA_HOURS=48
# PENDING_TX_REVIEW_SLA_HOURS=24

# ── Alerting / Cron ────────────────────────────────────────────────────────────
# ALERT_POLL_INTERVAL_MS=15000
# CRON_SECRET=your-cron-secret
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx
