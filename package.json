    "@tanstack/react-query": "^5.90.21",
    "@walletconnect/ethereum-provider": "^2.23.5",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.30.1",
    "drizzle-orm": "^0.38.2",
    "framer-motion": "^12.40.0",
    "lucide-react": "^0.468.0",
    "next": "15.5.12",
    "next-auth": "4.24.13",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.9.2",
    "siwe": "^3.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "viem": "^2.45.3",
    "wagmi": "^2.19.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "15.5.11",
    "postcss": "^8.4.49",
    "pptxgenjs": "^4.0.1",
    "tailwindcss": "^3.4.16",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2"
  },
